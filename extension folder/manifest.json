{
  "manifest_version": 3,
  "name": "JobStalker",
  "version": "1.0.0",
  "description": "Save job postings directly to your JobStalker account from LinkedIn",
  "permissions": [
    "activeTab",
    "storage", 
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://jobstalker.netlify.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/jobs/*"],
      "js": ["config.js", "ai-config.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobstalker.netlify.app/*"],
      "js": ["auth-check.js", "auth-content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config.js", "ai-config.js", "auth-check.js"],
      "matches": ["https://*.linkedin.com/*", "https://jobstalker.netlify.app/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
} 